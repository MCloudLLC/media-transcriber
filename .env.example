# ─────────────────────────────────────────────
# media-transcriber environment configuration
# Copy this file to .env and fill in your values.
# .env is loaded automatically on startup.
# ─────────────────────────────────────────────

# ── Azure Speech-to-Text (required for --backend azure) ──────────────────────
AZURE_SPEECH_KEY=your_azure_speech_api_key_here
AZURE_AI_LOCATION=eastus

# ── Q&A: OpenAI-compatible API key ───────────────────────────────────────────
# Required only when using OpenAI or a hosted LLM endpoint in the Q&A tab.
# Leave unset (or blank) when using Ollama — it needs no key.
OPENAI_API_KEY=your_openai_api_key_here
